# Dummy secrets for local `act` runs. Copy is not required — the .actrc already
# points --secret-file here.
#
# Under act, ACT=true makes the workflows run in MOCK mode, so this value is
# never used to reach the real Fastmail API; it only satisfies the
# ${{ secrets.FASTMAIL_API_TOKEN }} reference so the workflow parses and runs.
#
# Do NOT put a real Fastmail API token here, and do NOT put real addresses in the
# report routing values below — under act these only satisfy the secret
# references; the mock fixture (reports@example.net) is what actually sends.
FASTMAIL_API_TOKEN=mock-token-not-used-under-act
FASTMAIL_REPORT_FROM=reports@example.net
FASTMAIL_REPORT_TO=reports@example.net
