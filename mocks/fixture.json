{
  "_comment": "Fake Fastmail account for ACT / Pester. Uses only reserved example.* domains — never real addresses. '_mailbox' tags which mailbox an email lives in so the fake JMAP server can honour an Email/query inMailbox filter; it is never returned to callers. Expected discovery result: would-add alias1@example.net and alias4@example.net (both have known correspondent bob@example.com; adam@example.net is dropped as an existing identity; alias2/alias3 are dropped as one-way senders). reports@example.net is the identity used as the report From/To in tests.",
  "identities": [
    { "id": "i1", "email": "adam@example.net", "name": "Example User" },
    { "id": "i2", "email": "me@example.net", "name": "Example User" },
    { "id": "i3", "email": "reports@example.net", "name": "Example User" }
  ],
  "mailboxes": [
    { "id": "mb-inbox", "role": "inbox", "name": "Inbox" },
    { "id": "mb-sent", "role": "sent", "name": "Sent" },
    { "id": "mb-drafts", "role": "drafts", "name": "Drafts" }
  ],
  "emails": [
    { "id": "s1", "_mailbox": "mb-sent", "to": [{ "name": "Bob", "email": "bob@example.com" }], "cc": [], "bcc": [] },
    { "id": "s2", "_mailbox": "mb-sent", "to": [{ "name": "Carol", "email": "carol@example.org" }], "cc": [], "bcc": [] },
    { "id": "e1", "_mailbox": "mb-inbox", "from": [{ "name": "Bob", "email": "bob@example.com" }], "header:X-Delivered-To:asText:all": ["alias1@example.net"] },
    { "id": "e2", "_mailbox": "mb-inbox", "from": [{ "name": "Newsletter", "email": "news@newsletter.example" }], "header:X-Delivered-To:asText:all": ["alias2@example.net"] },
    { "id": "e3", "_mailbox": "mb-inbox", "from": [{ "name": "Carol", "email": "carol@example.org" }], "header:X-Delivered-To:asText:all": ["adam@example.net"] },
    { "id": "e4", "_mailbox": "mb-inbox", "from": [{ "name": "Dave", "email": "dave@vendor.example" }], "header:X-Delivered-To:asText:all": ["alias3@example.net"] },
    { "id": "e5", "_mailbox": "mb-inbox", "from": [{ "name": "Bob", "email": "bob@example.com" }], "header:X-Delivered-To:asText:all": ["alias4@example.net"] }
  ]
}
